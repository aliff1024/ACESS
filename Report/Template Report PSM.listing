-- Sends notification for ALL quiz attempts (pass and fail)
CREATE FUNCTION notify_on_quiz_attempt()
RETURNS TRIGGER AS $$
DECLARE
    v_lesson_title TEXT;
    v_learner_name TEXT;
    v_result_text TEXT;
BEGIN
    SELECT l.title INTO v_lesson_title
    FROM lessons l JOIN quizzes q ON q.lesson_id = l.id
    WHERE q.id = NEW.quiz_id;

    SELECT full_name INTO v_learner_name
    FROM users WHERE id = (
        SELECT user_id FROM enrollments WHERE id = NEW.enrollment_id
    );

    v_result_text := CASE WHEN NEW.result = 'pass'
        THEN 'passed' ELSE 'did not pass' END;

    INSERT INTO notifications (user_id, type, title, body, metadata)
    VALUES (
        (SELECT created_by FROM courses WHERE id = (
            SELECT course_id FROM enrollments WHERE id = NEW.enrollment_id
        )),
        'quiz_completed', 'Quiz Completed',
        v_learner_name || ' ' || v_result_text || ' the quiz: ' ||
            COALESCE(v_lesson_title, 'Unknown') || ' with score ' ||
            COALESCE(NEW.score_pct::text, 'N/A') || '%.',
        jsonb_build_object('attempt_id', NEW.id, 'score',
            NEW.score_pct, 'result', NEW.result)
    );
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER on_quiz_attempt_notify
AFTER INSERT ON quiz_attempts
FOR EACH ROW EXECUTE FUNCTION notify_on_quiz_attempt();
